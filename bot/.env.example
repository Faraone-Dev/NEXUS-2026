# ═══════════════════════════════════════════════════════════════════════════
#                        NEXUS AI - SOLANA EDITION
#                         Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# ─────────────────────────────────────────────────────────────────────────
#  AI PROVIDER (required)
# ─────────────────────────────────────────────────────────────────────────
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─────────────────────────────────────────────────────────────────────────
#  SOLANA RPC (required)
# ─────────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Helius — premium RPC, free tier available
# https://helius.dev
HELIUS_API_KEY=your-helius-uuid
HELIUS_RPC_URL=https://mainnet.helius-rpc.com

# ─────────────────────────────────────────────────────────────────────────
#  DATA APIs
# ─────────────────────────────────────────────────────────────────────────
# Jupiter — https://portal.jup.ag (free tier = 600 req/min)
JUPITER_API_KEY=your-jupiter-uuid
JUPITER_BASE_URL=https://api.jup.ag
JUPITER_PRICE_API=https://api.jup.ag/price/v3
JUPITER_QUOTE_API=https://api.jup.ag/swap/v1/quote
JUPITER_SWAP_API=https://api.jup.ag/swap/v1/swap

# Birdeye — https://birdeye.so/developers
BIRDEYE_API_KEY=your-birdeye-key
BIRDEYE_API_URL=https://public-api.birdeye.so

# DexScreener — no key needed
DEXSCREENER_API_URL=https://api.dexscreener.com/latest

# Solscan (optional)
SOLSCAN_API_URL=https://api.solscan.io
SOLSCAN_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
#  WALLET
# ─────────────────────────────────────────────────────────────────────────
# ⚠️  NEVER commit real private keys! Use a dedicated trading wallet.
SOLANA_PRIVATE_KEY=your-base58-private-key
SOLANA_WALLET_ADDRESS=your-wallet-address

# ─────────────────────────────────────────────────────────────────────────
#  TELEGRAM (optional — for trade alerts)
# ─────────────────────────────────────────────────────────────────────────
# https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────────────────────────────────
#  TRADING CONFIG
# ─────────────────────────────────────────────────────────────────────────
# R:R = 1:2 → positive expected value at 40%+ win rate
POSITION_SIZE_PERCENT=30
MAX_POSITIONS=3
STOP_LOSS_PERCENT=20
TAKE_PROFIT_PERCENT=40

# ─────────────────────────────────────────────────────────────────────────
#  FILTERS
# ─────────────────────────────────────────────────────────────────────────
MIN_LIQUIDITY_USD=15000
MIN_AI_SCORE=65
MIN_CONFIDENCE=70
MAX_TOKEN_AGE_HOURS=48

# ─────────────────────────────────────────────────────────────────────────
#  BOT SETTINGS
# ─────────────────────────────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=10
LOG_LEVEL=INFO
DRY_RUN=true

# Paper trading — uses real mainnet prices, no on-chain transactions
SIMULATION_MODE=true
SIMULATION_STARTING_SOL=1.0

# ─────────────────────────────────────────────────────────────────────────
#  AARNA MCP — Technical Analysis signals via Smithery Connect
# ─────────────────────────────────────────────────────────────────────────
# https://smithery.ai — get API key from dashboard
AARNA_API_KEY=your-smithery-api-key
AARNA_NAMESPACE=your-namespace
AARNA_CONNECTION=aarnaai-atars-mcp
AARNA_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────
#  SOCIAL (optional)
# ─────────────────────────────────────────────────────────────────────────
TWITTER_BEARER_TOKEN=
